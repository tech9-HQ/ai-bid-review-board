# ╔══════════════════════════════════════════════════════════════╗
# ║          AI Bid Review Board — Environment Config           ║
# ╠══════════════════════════════════════════════════════════════╣
# ║  Choose ONE backend by setting AI_BACKEND below.            ║
# ║  Comment out the section you are NOT using.                 ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Backend Selection ───────────────────────────────────────────────────────
# Options: "anthropic" | "bedrock"
AI_BACKEND=bedrock

# ── OPTION A: Direct Anthropic API ─────────────────────────────────────────
# Use this when AI_BACKEND=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# ── OPTION B: AWS Bedrock ───────────────────────────────────────────────────
# Use this when AI_BACKEND=bedrock
# Get these from your AWS Access Keys CSV file.
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1

# ── Claude Model IDs ────────────────────────────────────────────────────────
# Leave BLANK to use the auto-resolved defaults for your backend.
#
# If AI_BACKEND=anthropic  defaults are:
#   CLAUDE_FAST_MODEL=claude-sonnet-4-6
#   CLAUDE_LEGAL_MODEL=claude-opus-4-6
#
# If AI_BACKEND=bedrock  defaults are:
#   CLAUDE_FAST_MODEL=us.anthropic.claude-sonnet-4-6-20251115-v1:0
#   CLAUDE_LEGAL_MODEL=us.anthropic.claude-opus-4-6-20251015-v1:0
#
# Only set these if you want to override the defaults:
CLAUDE_FAST_MODEL=
CLAUDE_LEGAL_MODEL=

# ── AI Generation ───────────────────────────────────────────────────────────
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=4096

# ── File Handling ───────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs

# ── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=2.0.0
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Observability ────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Rate Limiting ────────────────────────────────────────────────────────────
MAX_CONCURRENT_JOBS=3
RATE_LIMIT_PER_MINUTE=10

