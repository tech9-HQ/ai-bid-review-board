# ─── AI PROVIDERS ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ─── APP SETTINGS ─────────────────────────────────────────────────────────────
APP_ENV=development                   # development | staging | production
APP_VERSION=1.0.0
SECRET_KEY=change-this-to-a-strong-random-secret

# ─── FILE STORAGE ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
OUTPUT_DIR=./outputs
MAX_UPLOAD_SIZE_MB=50

# ─── AI MODEL CONFIG ──────────────────────────────────────────────────────────
OPENAI_AUDIT_MODEL=gpt-4o
OPENAI_REWRITE_MODEL=gpt-4o
CLAUDE_LEGAL_MODEL=claude-opus-4-6
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=4096

# ─── SENTRY (optional) ────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
